# ── Telegram (aus deinem Bot übernehmbar) ─────────────────────────────────
TELEGRAM_TOKEN=dein_bot_token_hier
# NUR dieser Chat (das Kind) wird bedient. Leer lassen = erster Chat wird autorisiert.
TELEGRAM_ALLOWED_CHAT_ID=

# ── Spielleiter (OpenClaw, GPT-Abo via OAuth) ────────────────────────────────
# Befehl, der den GM-Agenten mit dem hogwarts-rpg-Skill aufruft. {session} = Chat-ID.
# Beispiel: openclaw run --skill hogwarts-rpg --session {session}
OPENCLAW_CMD=

# ── Moderation (Pflicht, OpenAI /moderations) ────────────────────────────────
# "openai" = OpenAI-Moderation-API (Key nötig). "local" = nur Offline-Wortliste.
MODERATION_MODE=openclaw
# Moderation nutzt DASSELBE GPT-OAuth wie der Spielleiter (kein Extra-Key):
OPENCLAW_MOD_MODEL=openai/gpt-5.5
OPENAI_MOD_KEY=sk-...nur-fuer-moderation
# Bei API-Fehler im Zweifel sperren (Kindersicherheit): 1 = ja
MODERATION_FAIL_CLOSED=1

# ── Daten ────────────────────────────────────────────────────────────────────
# Leer = Standard ~/.openclaw/skills/hogwarts-rpg/data
HOGWARTS_DATA_DIR=
